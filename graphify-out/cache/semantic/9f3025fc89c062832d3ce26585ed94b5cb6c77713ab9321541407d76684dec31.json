er", "design_storage_provider_interface", "design_local_storage_provider", "design_gdrive_provider"], "relation": "participate_in", "confidence": "EXTRACTED", "confidence_score": 0.9, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md"}, {"id": "sequential_learning_gate_flow", "label": "Sequential Learning Gate Flow", "nodes": ["design_quiz_gate", "design_prisma_data_model", "shared_DEFAULT_PASS_SCORE"], "relation": "implement", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md"}]}