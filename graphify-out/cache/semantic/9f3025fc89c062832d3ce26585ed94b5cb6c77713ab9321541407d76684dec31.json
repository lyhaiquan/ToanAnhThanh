{"nodes": [{"id": "design_toan_anh_thanh_lms", "label": "Toan Anh Thanh LMS Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_adapter_pattern", "label": "Adapter Pattern for Volatile Subsystems", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Kien truc / Nguyen tac mo rong", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Applied to the parts most likely to change (AI backend and video storage) so the demo can ship with mock/local implementations while remaining swap-ready for open-notebook and Google Drive once credentials/API keys exist."}, {"id": "design_ai_provider_interface", "label": "AIProvider Interface", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Tinh nang AI", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Contract (analyzeLecture, generateExercises, chat, generateSlides) decouples AI features from any specific LLM backend; selected via AI_PROVIDER env var."}, {"id": "design_mock_ai_provider", "label": "MockAIProvider", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Quyet dinh da chot", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Default provider returning real prepared math content per seeded lesson so the full AI flow is demoable without an LLM API key."}, {"id": "design_opennotebook_provider", "label": "OpenNotebookProvider", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "REST client to open-notebook (ON_API_URL, notebook per lesson); works when configured, raises a clear configuration error when env is missing."}, {"id": "design_storage_provider_interface", "label": "StorageProvider Interface", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "save() returns an opaque videoRef and createReadStream() supports Range, so the real file URL/location never reaches the client and backends are interchangeable."}, {"id": "design_local_storage_provider", "label": "LocalStorageProvider", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Default backend serving MP4s from apps/server/media/ for the local SQLite demo (no Docker, no cloud dependency)."}, {"id": "design_gdrive_provider", "label": "GoogleDriveProvider (stub)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Quyet dinh da chot", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Complete stub awaiting OAuth credentials; throws an instructive configuration error instead of failing silently."}, {"id": "design_quiz_gate", "label": "Quiz Gate (Sequential Unlock)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Tinh nang AI item 5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Students must reach passScore (default 70) on a lesson's quiz to unlock the next lesson; first lesson of the first chapter is always open. Enforces sequential learning (isLessonUnlocked in quiz service)."}, {"id": "design_stream_token", "label": "HMAC Signed Stream Token", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Bao mat noi dung", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Short-lived (60s) HMAC-SHA256 token bound to userId+lessonId on /api/stream/:lessonId; prevents URL sharing and hides the real file path. Client requests a fresh token on every play."}, {"id": "design_dynamic_watermark", "label": "Dynamic Moving Watermark", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Bao mat noi dung", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CSS overlay of user email + timestamp moving randomly over the video (pointer-events: none) to deter and trace screen recordings; server-side ffmpeg burn-in explicitly out of scope."}, {"id": "design_client_security_guard", "label": "Client Security Guard (Web Deterrents)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Bao mat noi dung", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Blocks context menu, F12/Ctrl+Shift+I/J/C, Ctrl+U/S/P; detects DevTools via window-size heuristic + debugger timing; on detection logs a SecurityEvent and force-logs-out. Applied only to STUDENT role. Honestly documented as deterrent-only on pure web."}, {"id": "design_electron_content_protection", "label": "Electron setContentProtection", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Bao mat noi dung", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Desktop app is the hard enforcement channel: setContentProtection(true) blacks out screen capture on Windows/macOS and setDisplayMediaRequestHandler is blocked, because pure web cannot block recording 100%."}, {"id": "design_rbac", "label": "RBAC (JWT + requireRole)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "RBAC & Admin", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "15-minute access token + refresh token; requireRole('ADMIN') middleware separates admin CRUD/monitoring from student learning flows; BANNED users cannot log in."}, {"id": "design_activity_logging", "label": "ActivityLog / SecurityEvent Monitoring", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Mo hinh du lieu", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every key action (login, video play/pause/seek, quiz, AI usage) is logged so admins get per-student timelines and prominent security alerts on the dashboard."}, {"id": "design_prisma_data_model", "label": "Prisma Data Model (User/Course/Chapter/Lesson/Quiz/Progress)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Mo hinh du lieu", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SQLite + Prisma chosen for zero-infrastructure local demo; Course->Chapter->Lesson tree with order fields drives both the content UI and the sequential gate."}], "edges": [{"source": "design_toan_anh_thanh_lms", "target": "design_adapter_pattern", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_adapter_pattern", "target": "design_ai_provider_interface", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_adapter_pattern", "target": "design_storage_provider_interface", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_mock_ai_provider", "target": "design_ai_provider_interface", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_opennotebook_provider", "target": "design_ai_provider_interface", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_local_storage_provider", "target": "design_storage_provider_interface", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_gdrive_provider", "target": "design_storage_provider_interface", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Nguyen tac mo rong", "weight": 1.0}, {"source": "design_toan_anh_thanh_lms", "target": "design_prisma_data_model", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-06-toan-anh-thanh-lms-design.md", "source_location": "Mo hinh d